{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "declaration": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "dist",

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/", "./tests/"],
  "exclude": ["./node_modules/", "./dist/"]
}
