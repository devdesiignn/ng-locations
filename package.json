{
  "name": "ng-locations",
  "version": "1.0.0",
  "description": "A zero-dependency TypeScript library for querying Nigerian states, LGAs, airports, universities, land mass, and geo-political zones.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nigeria",
    "nigerian",
    "states",
    "lga",
    "local-government",
    "capital",
    "universities",
    "airports",
    "land-mass",
    "geo-political-zone",
    "location",
    "africa"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devdesiignn/ng-locations.git"
  },
  "homepage": "https://github.com/devdesiignn/ng-locations#readme",
  "author": "Muiz Haruna (devdesiignn) <hmuiyze@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  }
}
